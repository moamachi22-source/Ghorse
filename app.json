{
  "expo": {
    "name": "قرص",
    "slug": "ghors",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ghors.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6C63FF"
      },
      "package": "com.ghors.app"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-av"
    ],
    "scheme": "ghors",
    "experiments": {
      "typedRoutes": true
    }
  }
}
